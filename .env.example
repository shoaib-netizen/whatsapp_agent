APP_ENV=dev
LOG_LEVEL=info

# WhatsApp session storage
WHATSAPP_DB_PATH=./data/whatsapp.db

# Google Sheets target
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1

# Absolute or relative path to your Google service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json

# Summary controls
SUMMARY_ENABLED=false
SUMMARY_EVERY_N_MESSAGES=10

# Optional LLM providers (set one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
